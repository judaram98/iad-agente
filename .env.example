# ============================================================
# AgentKit — Variables de entorno
# Copia este archivo: cp .env.example .env
# Llena los valores reales en .env
# NUNCA subas .env a GitHub
# ============================================================

# ── IA: Groq ─────────────────────────────────────────────────
# Obtener en: console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo a usar (puedes cambiarlo por llama-3.1-8b-instant para respuestas más rápidas)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Kommo CRM ─────────────────────────────────────────────────
# Subdominio sin https://, ej: miempresa.kommo.com
KOMMO_SUBDOMAIN=miempresa.kommo.com
# JWT long-lived: Kommo → Settings → Integrations → oAuth → long-lived token
KOMMO_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.placeholder
# ID del pipeline donde caen los leads (opcional — dejar vacío si no lo tienes aún)
KOMMO_PIPELINE_ID=
# Secreto para validar webhooks de Kommo. Genera con:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
KOMMO_WEBHOOK_SECRET=reemplaza_con_cadena_aleatoria_de_32_bytes

# ── Campos personalizados de Kommo (calificación de leads) ────
# IDs numéricos de los campos en Kommo → Settings → Fields.
# Si no están configurados, los datos se guardan como tags dato_campo:valor.
# Para encontrar los IDs: Kommo → Settings → Campos personalizados → hover sobre el campo.
KOMMO_FIELD_PRESUPUESTO=
KOMMO_FIELD_ZONA=
KOMMO_FIELD_TIPO=
KOMMO_FIELD_RECAMARAS=
KOMMO_FIELD_MOTIVO=
KOMMO_FIELD_URGENCIA=
KOMMO_FIELD_FORMA_PAGO=

# ── WhatsApp: Whapi.cloud ─────────────────────────────────────
# Solo necesario si AGENT_MODE=whapi
# Obtener en: whapi.cloud → Dashboard → API Token
WHAPI_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Inventario ────────────────────────────────────────────────
# Google Sheet → Archivo → Publicar en web → Formato: CSV → copiar URL
INVENTORY_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXXXXXX/pub?output=csv

# ── Modo del agente ───────────────────────────────────────────
# kommo  → usa Kommo como CRM y canal de mensajes
# whapi  → usa Whapi.cloud directamente
AGENT_MODE=whapi

# ── Servidor ─────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
# URL pública del servidor (Railway te la asigna)
BASE_URL=https://tu-app.up.railway.app

# ── Base de datos ─────────────────────────────────────────────
# Local con SQLite:
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Producción con PostgreSQL (Railway Postgres plugin):
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# ── Seguimiento de leads ──────────────────────────────────────
# Días sin contacto antes de enviar un seguimiento automático
FOLLOWUP_DIAS=3
